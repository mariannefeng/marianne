---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import type { MarkdownHeading } from 'astro';

type Props = CollectionEntry<'portfolio'>['data'] & { headings: MarkdownHeading[] };

const { title, description, headings } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<style slot="head">
			main {
				margin-bottom: 2em;
			}
			article {
				display: flex;
				margin: auto;
				justify-content: center;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.prose :global(.apostrophe-fix-right) {
				margin-right: -0.7em;
			}
			.prose :global(.apostrophe-fix-left) {
				margin-left: -0.7em;
			}

			.prose :global(a.github-link) {
				float: right;
				padding-right: 1rem;
			}
			.prose :global(a.github-link img) {
				height: 25px;
				width: 25px;
				margin-bottom: 0;
			}

			.prose :global(a.github-link:hover img) {
				transform: scale(1.1);
			}

			ul.headings {
				list-style-type: none;
				max-width: 250px;
				font-weight: 100;
				font-family: "jersey", sans-serif;
				border: 1px dotted;
				border-radius: 5px;
				margin-top: 0;
				line-height: 1.5;
				padding: 1em;

				--toc-fill-pct: 0%;
				background: linear-gradient(
					to bottom,
					#E2E0DF 0%,
					#E2E0DF var(--toc-fill-pct),
					transparent var(--toc-fill-pct)
				);
			}

			ul.headings li a {
				text-decoration: none;
			}

			@keyframes headings-link-pulse {
				0%,
				100% {
					opacity: 1;
				}
				50% {
					opacity: 0.7;
				}
			}

			ul.headings li a:hover {
				animation: headings-link-pulse 2s ease-in-out infinite;
			}

			p.table-of-contents-label {
				font-family: "jersey", sans-serif;
				text-align: right;	
				width: 95%;
				margin-bottom: 0;
				top: 13px;
				position: relative;
				padding-right: 1em;
			}

			p.table-of-contents-label span {
				background-color: white;
				border-radius: 5px;
				padding-left: .5em;
				padding-right: .5em;
			}

			div.table-of-contents {
				position: sticky;
				top: 1.5em;
				align-self: flex-start;
				margin-left: 1em;
				display: none;
			}

			@media screen and (min-width: 1024px) {
					div.table-of-contents {
						display: block;
					}
			}
		</style>
	<Header />
	<main>
		<article>
			<div class="prose apostrophe-fix-root">
				<slot />
			</div>
			
			{headings?.length > 0 && <div class="table-of-contents">
				<p class="table-of-contents-label"><span>jump to</span></p>
				<ul class="headings">
					{headings?.map((heading) => (
						<li style={{ paddingLeft: `${(heading.depth - 1)* 10}px` }}><a href={`#${heading.slug}`}>{heading.text}</a></li>
					))}
				</ul>
			</div>}

		</article>
	</main>
	<script>
		// Left/right curly single + left/right curly double (smartypants)
		const CURLY_LEFT = "\u2018\u201C";  // left single, left double
		const CURLY_QUOTES = CURLY_LEFT + "\u2019\u201D";
		function walkTextNodes(node: Node, fn: (textNode: Text) => void): void {
			if (node.nodeType === Node.TEXT_NODE) {
				fn(node as Text);
				return;
			}
			if (node.nodeType === Node.ELEMENT_NODE) {
				if ((node as Element).tagName === "PRE") return;
				Array.from(node.childNodes).forEach((child) => walkTextNodes(child, fn));
			}
		}

		// remove extra spaces after quotes because the font is Chinese
		document.querySelectorAll(".apostrophe-fix-root").forEach((root) => {
			walkTextNodes(root, (textNode: Text) => {
				const text = textNode.textContent ?? "";
				const hasCurly = [...CURLY_QUOTES].some((c) => text.includes(c));
				if (!hasCurly) return;
				const fragment = document.createDocumentFragment();
				let run = "";
				for (let i = 0; i < text.length; i++) {
					const ch = text[i];
					if (CURLY_QUOTES.includes(ch)) {
						if (run.length) {
							fragment.appendChild(document.createTextNode(run));
							run = "";
						}
						const span = document.createElement("span");
						span.className = CURLY_LEFT.includes(ch) ? "apostrophe-fix-left" : "apostrophe-fix-right";
						span.textContent = ch;
						fragment.appendChild(span);
					} else {
						run += ch;
					}
				}
				if (run.length) fragment.appendChild(document.createTextNode(run));
				textNode.parentNode?.replaceChild(fragment, textNode);
			});
		});

		// custom editor behavior
		document.addEventListener("click", async function (e) {
			// find the copy button
			const target = e.target as HTMLElement;
			let copyLink: HTMLElement | null = null;
			if (target.closest) {
				copyLink = target.closest("a.copy-link");
			}

			if (!copyLink) {
				console.log("no copy link found");
				return;
			}

			e.preventDefault();

			// Find the associated code
			const codeContainer = copyLink.closest(".code-container");
			if (!codeContainer) return;

			const code = codeContainer.querySelector("code");
			if (!code) return;

			const copyLinkText = codeContainer.querySelector<HTMLElement>("span.copy-link-text");
			if (!copyLinkText) return;

			let textToCopy = code.textContent ?? "";
			let msgTimeout = 1000;

			try {
				await navigator.clipboard.write([
					new ClipboardItem({ "text/plain": textToCopy }),
				]);
				copyLinkText.textContent = "copied!";
			} catch (error) {
				console.error("Error copying to clipboard: ", error);
				copyLinkText.textContent = "error copying";
				msgTimeout = 3000;
			}

			copyLinkText.style.setProperty("display", "block");

			setTimeout(() => {
				copyLinkText.style.setProperty("display", "none");
			}, msgTimeout);
		});

		// table of contents
		const proseEl = document.querySelector("article .prose") as HTMLElement | null;
		const tocEl = document.querySelector("ul.headings") as HTMLElement | null;
		if (proseEl !== null && tocEl !== null) {
			const prose = proseEl;
			const toc = tocEl;

			let ticking = false;

			function articleReadProgress(el: HTMLElement): number {
				const rect = el.getBoundingClientRect();
				const scrollY = window.scrollY;
				const topDoc = scrollY + rect.top;
				const height = el.offsetHeight;
				const vh = window.innerHeight;
				const range = Math.max(height - vh, 1);
				return Math.min(1, Math.max(0, (scrollY - topDoc) / range));
			}

			function updateTocFill(): void {
				const p = articleReadProgress(prose);
				const currentlyDotted = toc.style.borderStyle === "dotted";

				toc.style.setProperty("--toc-fill-pct", `${p * 100}%`);
				ticking = false;

				if (p >= 1 && currentlyDotted) {
					toc.style.borderStyle = "solid";
				} else if (p < 1 && !currentlyDotted) {
					toc.style.borderStyle = "dotted";
				}
			}

			function onScrollOrResize(): void {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(updateTocFill);
			}

			window.addEventListener("scroll", onScrollOrResize, { passive: true });
			window.addEventListener("resize", onScrollOrResize, { passive: true });
			new ResizeObserver(onScrollOrResize).observe(prose);

			updateTocFill();
		}

		function randomHeadingLinkColor(): string {
			const h = Math.random() * 360;
			return `hsl(${h} 72% 36%)`;
		}

		document.querySelectorAll("ul.headings li a").forEach((anchor) => {
			const el = anchor as HTMLAnchorElement;
			el.addEventListener("mouseenter", () => {
				el.style.color = randomHeadingLinkColor();
			});
			el.addEventListener("mouseleave", () => {
				el.style.removeProperty("color");
			});
		});
	</script>
</BaseLayout>
